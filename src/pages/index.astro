---
import Layout from "../layouts/layout.astro";
---

<Layout title="Moya Tools - 개발자 도구 모음">
  <!-- Navbar -->
  <div class="navbar bg-base-100">
    <div class="flex-1">
      <a class="btn btn-ghost text-2xl font-bold">Moya</a>
    </div>
  </div>

  <!-- Hero Section -->
  <div class="hero min-h-[60vh] bg-base-200">
    <div class="hero-content text-center">
      <div class="max-w-2xl">
        <div class="badge badge-outline badge-lg mb-6">v1.0.0 Alpha</div>
        <h1 class="text-5xl font-bold">웹 개발을 위한 최고의 도구들</h1>
        <p class="py-6 text-lg">
          복잡한 작업은 저희에게 맡기세요. <br class="hidden md:inline" />
          Moya Tools는 개발 생산성을 높여주는 다양한 유틸리티를 무료로 제공합니다.
        </p>
        <div class="flex gap-4 justify-center">
          <button class="btn btn-primary btn-lg"> 시작하기 </button>
          <button class="btn btn-soft btn-lg">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="w-6 h-6 mr-2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"
              ></path>
            </svg>
            문서 보기
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- CTA Section -->
  <section class="py-20 px-4">
    <div class="container mx-auto max-w-4xl text-center">
      <div class="card bg-base-200">
        <div class="card-body items-center text-center">
          <h2 class="card-title text-3xl mb-4">필요한 도구가 없나요?</h2>
          <p class="opacity-70 mb-8 max-w-xl">
            Moya Tools는 지속적으로 업데이트됩니다. <br />
            필요한 기능을 요청해주시면 빠르게 반영하겠습니다.
          </p>
          <button class="btn btn-primary">기능 요청하기</button>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer
    class="footer footer-center p-10 bg-base-100 text-base-content rounded"
  >
    <div class="grid grid-flow-col gap-4">
      <a class="link link-hover">About us</a>
      <a class="link link-hover">Contact</a>
      <a class="link link-hover">Privacy Policy</a>
      <a class="link link-hover">Terms</a>
    </div>
    <div>
      <div class="grid grid-flow-col gap-4">
        <a
          ><svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            class="fill-current"
            ><path
              d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 2.404-4.69 4.181-7.534 4.181-.49 0-.972-.031-1.442-.09 2.712 1.739 5.925 2.756 9.407 2.756 11.285 0 17.487-9.264 17.487-17.514 0-.256-.005-.515-.015-.77 1.201-.869 2.249-1.956 3.085-3.086z"
            ></path></svg
          ></a
        >
        <a
          ><svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            class="fill-current"
            ><path
              d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"
            ></path></svg
          ></a
        >
      </div>
    </div>
    <div>
      <p>Copyright © 2026 - All right reserved by Moya</p>
    </div>
  </footer>
</Layout>
