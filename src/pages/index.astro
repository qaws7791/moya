---
import Layout from "../layouts/layout.astro";
import { tools } from "../config/tools";
import { getFluentEmojiUrl } from "../utils/fluent-emoji";
---

<Layout title="Moya Tools - 개발자 도구 모음">
  <!-- Hero Section -->
  <div class="hero bg-base-200 min-h-[60vh]">
    <div class="hero-content text-center">
      <div class="max-w-2xl">
        <div
          class="badge badge-soft badge-lg text-primary border-primary/20 bg-primary/10 mb-6"
        >
          v1.0.0 Alpha
        </div>
        <h1 class="text-5xl font-extrabold tracking-tight md:text-6xl">
          웹 개발을 위한 <br />
          <span
            class="from-primary to-secondary bg-gradient-to-r bg-clip-text text-transparent"
          >
            최고의 도구들
          </span>
        </h1>
        <p class="py-8 text-lg leading-relaxed opacity-80">
          복잡한 작업은 저희에게 맡기세요. <br class="hidden md:inline" />
          Moya Tools는 개발 생산성을 높여주는 다양한 유틸리티를 무료로 제공합니다.
        </p>
        <div class="flex justify-center gap-4">
          <a
            href="#tools"
            class="btn btn-primary btn-lg shadow-primary/20 shadow-lg"
          >
            시작하기
          </a>
          <button class="btn btn-soft btn-lg">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="mr-2 h-6 w-6"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"
              ></path>
            </svg>
            문서 보기
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Tools Section -->
  <section
    id="tools"
    class="container mx-auto max-w-7xl px-4 py-24"
  >
    <div class="mb-16 flex flex-col items-center text-center">
      <h2 class="mb-4 text-4xl font-bold">제공되는 도구들</h2>
      <div class="bg-primary h-1.5 w-20 rounded-full"></div>
    </div>
    <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
      {
        tools.map((tool) => (
          <a
            href={tool.href}
            class="group card bg-base-100 border-base-content/5 hover:border-primary/20 border shadow-xl transition-all duration-300 hover:-translate-y-2 hover:shadow-2xl"
          >
            <div class="card-body">
              <div
                class={`h-16 w-16 rounded-2xl bg-${tool.color}/5 mb-4 flex items-center justify-center p-2 transition-transform group-hover:scale-110 group-hover:rotate-3`}
              >
                <img
                  src={getFluentEmojiUrl(tool.emoji, "3d")}
                  alt={tool.name}
                  class="h-full w-full object-contain"
                  loading="lazy"
                />
              </div>
              <h2 class="card-title group-hover:text-primary mb-2 text-2xl font-bold transition-colors">
                {tool.name}
              </h2>
              <p class="leading-relaxed opacity-70">{tool.description}</p>
              <div class="card-actions mt-6 justify-end">
                <span class="btn btn-sm btn-ghost gap-2 transition-all group-hover:gap-3">
                  바로가기
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="lucide lucide-arrow-right"
                  >
                    <>
                      <path d="M5 12h14" />
                      <path d="m12 5 7 7-7 7" />
                    </>
                  </svg>
                </span>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <!-- CTA Section -->
  <section class="px-4 py-20">
    <div class="container mx-auto max-w-4xl text-center">
      <div class="card bg-base-200">
        <div class="card-body items-center text-center">
          <h2 class="card-title mb-4 text-3xl">필요한 도구가 없나요?</h2>
          <p class="mb-8 max-w-xl opacity-70">
            Moya Tools는 지속적으로 업데이트됩니다. <br />
            필요한 기능을 요청해주시면 빠르게 반영하겠습니다.
          </p>
          <button class="btn btn-primary">기능 요청하기</button>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer
    class="footer footer-center bg-base-100 text-base-content rounded p-10"
  >
    <div class="grid grid-flow-col gap-4">
      <a class="link link-hover">About us</a>
      <a class="link link-hover">Contact</a>
      <a class="link link-hover">Privacy Policy</a>
      <a class="link link-hover">Terms</a>
    </div>
    <div>
      <div class="grid grid-flow-col gap-4">
        <a
          ><svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            class="fill-current"
            ><path
              d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 2.404-4.69 4.181-7.534 4.181-.49 0-.972-.031-1.442-.09 2.712 1.739 5.925 2.756 9.407 2.756 11.285 0 17.487-9.264 17.487-17.514 0-.256-.005-.515-.015-.77 1.201-.869 2.249-1.956 3.085-3.086z"
            ></path></svg
          ></a
        >
        <a
          ><svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            class="fill-current"
            ><path
              d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"
            ></path></svg
          ></a
        >
      </div>
    </div>
    <div>
      <p>Copyright © 2026 - All right reserved by Moya</p>
    </div>
  </footer>
</Layout>
