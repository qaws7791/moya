---
import { tools } from "../config/tools";
---

<div class="pointer-events-none sticky top-4 z-50 px-4 md:px-8">
  <div
    class="navbar bg-base-100/50 border-base-content/10 pointer-events-auto mx-auto max-w-7xl rounded-full border px-4 shadow-sm backdrop-blur-xl md:px-8"
  >
    <div class="navbar-start">
      <div class="dropdown">
        <div
          tabindex="0"
          role="button"
          class="btn btn-ghost lg:hidden"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h8m-8 6h16"
            ></path>
          </svg>
        </div>
        <ul
          tabindex="0"
          class="menu menu-sm dropdown-content bg-base-100 rounded-box z-[1] mt-3 w-52 p-2 shadow"
        >
          <li><a href="/">홈</a></li>
          <li>
            <a>도구 목록</a>
            <ul class="p-2">
              {
                tools.map((tool) => (
                  <li>
                    <a href={tool.href}>{tool.name}</a>
                  </li>
                ))
              }
            </ul>
          </li>
        </ul>
      </div>
      <a
        href="/"
        class="btn btn-ghost gap-0 text-2xl font-black tracking-tighter"
      >
        <span class="text-primary">Moya</span>
        <span class="opacity-50">.tools</span>
      </a>
    </div>
    <div class="navbar-center hidden lg:flex">
      <ul class="menu menu-horizontal gap-2 px-1">
        <li>
          <a
            href="/"
            class="py-1.5 font-medium"
            >홈</a
          >
        </li>
        <li
          tabindex="0"
          class="dropdown dropdown-hover"
        >
          <div
            role="button"
            class="flex items-center gap-1 py-1.5 font-medium"
          >
            도구들
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 opacity-50"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 9l-7 7-7-7"
              ></path>
            </svg>
          </div>
          <ul
            class="dropdown-content menu bg-base-100 rounded-box border-base-content/5 z-[1] mt-0 w-64 border p-2 shadow-2xl"
          >
            {
              tools.map((tool) => (
                <li>
                  <a
                    href={tool.href}
                    class="hover:bg-base-200 flex flex-col items-start px-4 py-3 transition-colors"
                  >
                    <span class={`text-sm font-bold text-${tool.color}`}>
                      {tool.name}
                    </span>
                    <span class="line-clamp-1 text-sm opacity-60">
                      {tool.description}
                    </span>
                  </a>
                </li>
              ))
            }
          </ul>
        </li>
      </ul>
    </div>
    <div class="navbar-end">
      <a
        href="https://github.com"
        class="btn btn-ghost btn-circle btn-sm"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="lucide lucide-github"
          ><path
            d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.28 1.15-.28 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
          ></path><path d="M9 18c-4.51 2-5-3-7-3"></path></svg
        >
      </a>
    </div>
  </div>
</div>
